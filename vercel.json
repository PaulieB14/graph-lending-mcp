{
  "version": 2,
  "buildCommand": "npm run build && cd dashboard && npm install && npx vite build",
  "outputDirectory": "dashboard/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" }
  ],
  "functions": {
    "api/index.js": {
      "memory": 256,
      "maxDuration": 30
    }
  }
}
